<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI Grammar Genius</title>

    <!-- Bootstrap -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Font Awesome -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />

    <!-- Google Font -->
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <style>
      * {
        font-family: "Poppins", sans-serif;
      }

      body {
       
        min-height: 100vh;
  background: linear-gradient(135deg, #0f172a, #1e293b);
}
      

      .hero-section {
        text-align: center;
        padding: 40px 0;
      }

      .hero-icon {
        width: 90px;
        height: 90px;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: auto;
        font-size: 40px;
        box-shadow: 0 10px 25px rgba(79, 70, 229, 0.3);
      }

      .hero-title {
        font-size: 3rem;
        font-weight: 700;
        margin-top: 20px;
        color: #f3f3f3;
      }

      .hero-text {
        color: #f7f7f7;
        font-size: 1.1rem;
      }

      .custom-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        transition: 0.3s;
      }

      .custom-card:hover {
        transform: translateY(-5px);
      }

      .card-title {
        font-weight: 600;
        color: #1e293b;
      }

      textarea {
        border-radius: 12px !important;
        resize: none;
        padding: 15px !important;
        border: 1px solid #cbd5e1 !important;
      }

      textarea:focus {
        box-shadow: 0 0 0 0.2rem rgba(79, 70, 229, 0.2) !important;
        border-color: #4f46e5 !important;
      }

      .btn-custom {
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        border: none;
        border-radius: 12px;
        padding: 12px 25px;
        font-weight: 500;
        transition: 0.3s;
      }

      .btn-custom:hover {
        transform: scale(1.03);
        background: linear-gradient(135deg, #4338ca, #6d28d9);
      }

      .output-box {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 20px;
        min-height: 180px;
        color: #334155;
      }

      .feature-box {
        background: white;
        border-radius: 18px;
        padding: 25px;
        text-align: center;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
        transition: 0.3s;
        height: 100%;
      }

      .feature-box:hover {
        transform: translateY(-6px);
      }

      .feature-icon {
        font-size: 45px;
        margin-bottom: 15px;
      }

      .feature-title {
        font-weight: 600;
        color: #1e293b;
      }

      .feature-text {
        color: #64748b;
        font-size: 14px;
      }
    </style>
  </head>

  <body>
    <div class="container py-5">

      <!-- Hero Section -->
      <div class="hero-section">
        <div class="hero-icon">
          <i class="fas fa-robot"></i>
        </div>

        <h1 class="hero-title">AI Grammar Genius</h1>

        <p class="hero-text">
       Perfect your writing instantly with intelligent AI-powered grammar correction.
        </p>
      </div>

      <!-- Main Section -->
      <div class="row g-4">

        <!-- Input -->
        <div class="col-lg-6">
          <div class="card custom-card h-100">
            <div class="card-body p-4">

              <h3 class="card-title mb-3">
                <i class="fas fa-keyboard text-primary me-2"></i>
                Enter Your Text
              </h3>

              <p class="text-muted">
                Paste or type your text below and let AI enhance it.
              </p>

              <form action="/correct" method="POST">

                <div class="mb-3">
                  <textarea
                    class="form-control"
                    name="text"
                    rows="8"
                    placeholder="Type your text here..."
                    required
                  >
                <%= originalText || '' %></textarea>
                </div>

                <button type="submit" class="btn btn-custom text-white w-100">
                  <i class="fas fa-wand-magic-sparkles me-2"></i>
                  Correct Grammar
                </button>

              </form>
            </div>
          </div>
        </div>

        <!-- Output -->
        <div class="col-lg-6">
          <div class="card custom-card h-100">
            <div class="card-body p-4">

              <h3 class="card-title mb-3">
                <i class="fas fa-check-circle text-success me-2"></i>
                Corrected Output
              </h3>

              <p class="text-muted">
                Your improved text will appear here.
              </p>

              <div class="output-box">

                <% if(corrected) { %>
                  <%= corrected %>
                <% } else { %>
                  <p class="text-muted">
                    No corrected text available yet.
                  </p>
                <% } %>

              </div>

            </div>
          </div>
        </div>

      </div>

      <!-- Features -->
      <div class="row mt-5 g-4">

        <div class="col-md-4">
          <div class="feature-box">
            <i class="fas fa-bolt feature-icon text-warning"></i>
            <h4 class="feature-title">Fast Processing</h4>
            <p class="feature-text">
              Get instant grammar corrections in seconds.
            </p>
          </div>
        </div>

        <div class="col-md-4">
          <div class="feature-box">
            <i class="fas fa-brain feature-icon text-info"></i>
            <h4 class="feature-title">Smart AI</h4>
            <p class="feature-text">
              AI understands sentence structure and context.
            </p>
          </div>
        </div>

        <div class="col-md-4">
          <div class="feature-box">
            <i class="fas fa-shield-alt feature-icon text-success"></i>
            <h4 class="feature-title">Reliable Results</h4>
            <p class="feature-text">
              Clean, accurate, and professional writing corrections.
            </p>
          </div>
        </div>

      </div>

    </div>
  </body>
</html>